{
  "name": "@base-ecommerce/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/run-next.mjs dev",
    "build": "node ./scripts/run-next.mjs build",
    "start": "node ./scripts/run-next.mjs start",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "npm run cf:build && opennextjs-cloudflare preview",
    "deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@base-ecommerce/domain": "file:../../packages/domain",
    "@base-ecommerce/ui": "file:../../packages/ui",
    "@base-ecommerce/validation": "file:../../packages/validation",
    "@tanstack/react-table": "^8.21.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.7",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.7",
    "wrangler": "^4.72.0"
  }
}
